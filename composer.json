{
  "name": "tearoom1/kirby-meta-kit",
  "description": "AI-powered SEO plugin for Kirby with meta descriptions, previews, and Schema.org",
  "type": "kirby-plugin",
  "license": "MIT",
  "homepage": "https://github.com/tearoom1/kirby-meta-kit",
  "version": "2.0.2",
  "keywords": [
    "kirby",
    "panel",
    "seo",
    "meta"
  ],
  "extra": {
    "installer-name": "meta-kit"
  },
  "authors": [
    {
      "name": "Mathis Koblin",
      "email": "mail@tearoom.one",
      "homepage": "https://www.tearoom.one",
      "role": "Maintainer"
    }
  ],
  "support": {
    "docs": "https://github.com/tearoom1/kirby-meta-kit/blob/main/README.md",
    "source": "https://github.com/tearoom1/kirby-meta-kit"
  },
  "require": {
    "php": "^8.1",
    "getkirby/composer-installer": "^1.2",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "TearoomOne\\": "classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TearoomOne\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  }
}
